{
  "name": "flutter-fahhh-architect",
  "displayName": "Flutter Fahhh Architect",
  "description": "Scaffold opinionated Flutter apps with clean architecture, state management wiring, and safe pubspec patching.",
  "version": "1.0.0",
  "publisher": "imShub",
  "author": "Shubham Madhav Waghmare",
  "repository": {
    "type": "git",
    "url": "https://github.com/imShub/flutter-fahhh-architect.git"
  },
  "homepage": "https://github.com/imShub/flutter-fahhh-architect",
  "bugs": {
    "url": "https://github.com/imShub/flutter-fahhh-architect/issues"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "flutter",
    "dart",
    "architecture",
    "clean architecture",
    "mvvm",
    "riverpod",
    "bloc",
    "provider",
    "scaffolding",
    "code generation"
  ],
  "activationEvents": [
    "onCommand:flutterFahhhArchitect.createApp",
    "onCommand:flutterFahhhArchitect.support",
    "onCommand:flutter-fahhh-architect.createApp",
    "onCommand:flutter-fahhh-architect.support"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "flutterFahhhArchitect.createApp",
        "title": "Flutter Fahhh: Create App",
        "category": "Flutter Fahhh Architect"
      },
      {
        "command": "flutterFahhhArchitect.support",
        "title": "Flutter Fahhh: Support (Buy Me a Coffee)",
        "category": "Flutter Fahhh Architect"
      },
      {
        "command": "flutter-fahhh-architect.createApp",
        "title": "Flutter Fahhh: Create App (legacy id)",
        "category": "Flutter Fahhh Architect"
      },
      {
        "command": "flutter-fahhh-architect.support",
        "title": "Flutter Fahhh: Support (legacy id)",
        "category": "Flutter Fahhh Architect"
      }
    ],
    "configuration": {
      "title": "Flutter Fahhh Architect",
      "properties": {
        "flutterFahhhArchitect.defaultArchitecture": {
          "type": "string",
          "enum": [
            "Clean Architecture",
            "MVVM"
          ],
          "default": "Clean Architecture",
          "description": "Default architecture when creating a new Flutter app."
        },
        "flutterFahhhArchitect.defaultStateManagement": {
          "type": "string",
          "enum": [
            "Riverpod",
            "Bloc",
            "Provider"
          ],
          "default": "Riverpod",
          "description": "Default state management when creating a new Flutter app."
        },
        "flutterFahhhArchitect.humorMode": {
          "type": "string",
          "enum": [
            "professional",
            "balanced",
            "chaotic"
          ],
          "default": "balanced",
          "description": "Controls how playful the console output is."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "fs-extra": "^11.3.3"
  },
  "files": [
    "dist/**",
    "templates/**",
    "images/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}